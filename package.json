{
  "name": "getreqly",
  "version": "1.0.5",
  "description": "",
  "main": "dist/server/index.js",
  "bin": {
    "reqly": "dist/server/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "dist",
    "packages/reqly-middleware/src/core.ts",
    "packages/reqly-middleware/src/index.ts",
    "packages/reqly-middleware/src/next.ts",
    "packages/reqly-middleware/package.json",
    "example/reqly-starter",
    "README.md",
    "llms.txt"
  ],
  "workspaces": [
    "packages/*"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "tsc && cd src/ui && npm install && npm run build && cd ../.. && rm -rf dist/ui && cp -R src/ui/dist dist/ui",
    "build:ui": "cd src/ui && npm run build && cd ../.. && rm -rf dist/ui && cp -R src/ui/dist dist/ui",
    "test": "vitest run",
    "start": "node dist/server/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RutvikPansare/Reqly.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RutvikPansare/Reqly/issues"
  },
  "homepage": "https://github.com/RutvikPansare/Reqly#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/multer": "^2.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^5.1.0",
    "localtunnel": "^2.0.2",
    "multer": "^2.2.0",
    "node-pty": "^1.1.0",
    "swagger-parser": "^10.0.3",
    "undici": "^8.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "node-pty@1.1.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
