{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CollectionMeta",
  "definitions": {
    "CollectionMeta": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "auth": {
          "$ref": "#/definitions/CollectionAuth"
        },
        "spec": {
          "$ref": "#/definitions/CollectionSpec"
        }
      },
      "additionalProperties": false
    },
    "CollectionAuth": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "profileId": {
          "type": "string"
        },
        "credentials": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "CollectionSpec": {
      "type": "object",
      "properties": {
        "specPath": {
          "type": "string"
        },
        "specUrl": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "title": "Reqly collection metadata",
  "description": "Collection-level metadata (.reqly/<collection>/collection.yaml)"
}
