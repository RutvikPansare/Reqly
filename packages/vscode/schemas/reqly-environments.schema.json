{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/EnvironmentStore",
  "definitions": {
    "EnvironmentStore": {
      "type": "object",
      "properties": {
        "active": {
          "type": "string"
        },
        "environments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Environment"
          }
        }
      },
      "required": [
        "environments"
      ],
      "additionalProperties": false
    },
    "Environment": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "variables"
      ],
      "additionalProperties": false
    }
  },
  "title": "Reqly environments",
  "description": "Environment store (.reqly/environments.yaml)"
}
